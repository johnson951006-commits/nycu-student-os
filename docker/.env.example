# Local Docker Compose environment. Copy to docker/.env before running.
# docker/.env is gitignored (see .gitignore). These are LOCAL, non-secret dev values;
# real secrets live in Secret Manager (OPS §1) and never appear here or in the repo.
POSTGRES_USER=nycu
POSTGRES_PASSWORD=nycu_local_dev
POSTGRES_DB=nycu
POSTGRES_PORT=5432
REDIS_PORT=6379
PUBSUB_PROJECT_ID=nycu-local
PUBSUB_PORT=8085
FIXTURE_PORTAL_PORT=8080
PGBOUNCER_PORT=6432
