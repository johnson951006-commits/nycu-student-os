# Backend environment (BIS §1.5). Copy to backend/.env for local runs (gitignored).
# Only the core variables are required at boot now; infrastructure/secret variables
# are typed but optional at scaffold time and become required as their consumers
# land (DATABASE_URL → INFRA-005; REDIS_URL/JWT/KMS → INFRA-006; FCM → INFRA-010).
# Real secrets live in Secret Manager (OPS §1), never here.

# --- core (required) ---
APP_PROFILE=api            # api | sync-worker | notif-worker | jobs
NODE_ENV=development       # development | test | production
PORT=8080
LOG_LEVEL=info             # debug | info | warn | error

# --- data tier (INFRA-005 / §6.1) — pooled + direct clients ---
# DATABASE_URL=postgresql://nycu:nycu_local_dev@localhost:6432/nycu?pgbouncer=true&connection_limit=5
# DATABASE_DIRECT_URL=postgresql://nycu:nycu_local_dev@localhost:5432/nycu?connection_limit=2
# REDIS_URL=redis://localhost:6379

# --- auth / crypto (INFRA-006) ---
# JWT_PRIVATE_KEY_PEM=
# JWT_PUBLIC_JWKS=
# KMS_KEY_PORTAL_COOKIES=

# --- messaging (INFRA-010) ---
# FIREBASE_SERVICE_ACCOUNT=
# PUBSUB_TOPIC_SYNC=sync.jobs
# PUBSUB_TOPIC_EVENTS=sync.events
# PUBSUB_TOPIC_NOTIF=notif.dispatch

# --- portal client (sync-worker) ---
# PORTAL_BASE_URLS=
# PORTAL_MAX_CONCURRENCY=40
# PORTAL_MAX_RPS=25

# --- observability / internal ---
# OTEL_EXPORTER_OTLP_ENDPOINT=
# LOG_HASH_KEY=
# INTERNAL_AUDIENCE=
